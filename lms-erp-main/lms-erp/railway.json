{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd lms-erp-main/backend && npm install && npm run build",
    "watchPatterns": [
      "lms-erp-main/backend/src/**",
      "lms-erp-main/backend/package.json"
    ]
  },
  "deploy": {
    "startCommand": "cd lms-erp-main/backend && npm run start:prod",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
